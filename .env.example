# ───────────────────────────────────────────────────────────────────────────────
# ArtiBot — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ATTENTION : Ne jamais committer le fichier .env dans git
# ───────────────────────────────────────────────────────────────────────────────

# ── IA / LLM + Embeddings ──────────────────────────────────────────────────────
# OpenAI — GPT-4o (LLM principal) + text-embedding-3-small (RAG)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXX

# Voyage AI — embeddings alternatifs (optionnel, meilleure qualité RAG)
# https://www.voyageai.com/
VOYAGE_API_KEY=pa-XXXXXXXXXXXX

# ── Google / Gmail OAuth ───────────────────────────────────────────────────────
# Créer un projet Google Cloud → OAuth 2.0 → Credentials
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=XXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXX
# ID du projet Google Cloud pour Pub/Sub
GOOGLE_PUBSUB_PROJECT_ID=artibot-production

# ── Twilio SMS ─────────────────────────────────────────────────────────────────
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXX

# ── Resend (emails transactionnels) ───────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXX

# ── Clerk (authentification) ──────────────────────────────────────────────────
# https://clerk.com/ → Votre application → API Keys
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXX
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXX

# ── Chiffrement ────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=XXXXXXXXXXXX=

# ── Base de données ────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_en_production
DATABASE_URL=postgresql://artibot:changeme_en_production@db:5432/artibot

# ── URLs ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# En production : https://api.artibot.fr

# ── Artisan ID (frontend) ──────────────────────────────────────────────────────
# ID de l'artisan connecté (en prod, récupéré depuis Clerk)
NEXT_PUBLIC_ARTISAN_ID=votre-artisan-uuid-ici
